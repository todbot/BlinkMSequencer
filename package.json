{
  "name": "blinkm-sequencer",
  "version": "0.2.0",
  "description": "BlinkM Sequencer for LinkM (USB HID)",
  "author": "Tod Kurt <tod@todbot.com> (https://github.com/todbot)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "debug": "npx cross-env BLINKM_DEVTOOLS=1 electron .",
    "rebuild": "electron-rebuild -f -w node-hid",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:mac:unsigned": "electron-builder --mac --publish never --dir --config build/unsigned.yml",
    "dist:mac:universal": "electron-builder --mac --universal --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:win:unsigned": "electron-builder --win --publish never --dir --config build/unsigned.yml",
    "dist": "electron-builder --mac --win --publish never",
    "clean": "npx rimraf dist node_modules",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "node-hid": "^3.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "@electron/rebuild": "^3.6.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.thingm.blinkmsequencer",
    "productName": "BlinkMSequencer",
    "copyright": "Copyright © 2026 ThingM",
    "icon": "build/icon",
    "asarUnpack": [
      "node_modules/node-hid/**/*"
    ],
    "files": [
      "main.js",
      "linkm.js",
      "preload.js",
      "color-chooser.js",
      "renderer.js",
      "index.html",
      "style.css"
    ],
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "writeUpdateInfo": false
    },
    "mac": {
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "azureSignOptions": {
        "endpoint": "https://wus2.codesigning.azure.net/",
        "codeSigningAccountName": "thingm-signing",
        "certificateProfileName": "ThingMProfile"
      },
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": null,
      "artifactName": "${productName}-Setup-${version}.exe",
      "differentialPackage": false
    }
  }
}
